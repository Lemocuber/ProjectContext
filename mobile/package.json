    "expo-av": "^16.0.8",
    "expo-file-system": "^55.0.10",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-live-audio-stream": "^1.1.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  }
